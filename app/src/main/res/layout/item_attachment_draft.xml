<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="6dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivAttachmentThumb"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:scaleType="centerCrop"
        android:contentDescription="附件预览" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAttachmentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:ellipsize="middle"
            android:textColor="@color/proxy_text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvAttachmentMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/proxy_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnAttachmentRemove"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="移除"
        android:textColor="@color/proxy_primary_dark"
        android:textSize="12sp" />
</LinearLayout>
